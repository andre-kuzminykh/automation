                    <i class="ph-bold ph-arrow-right text-gray-300 mx-2"></i>
                    <div class="w-[45%] bg-purple-50 text-purple-700 text-[9px] md:text-sm font-bold px-3 py-2 rounded-lg text-center">Интервью и наблюдение</div>
                </div>
                <div class="bg-gray-50 border border-gray-200 rounded-xl p-3 md:p-4 flex flex-row items-center justify-between shadow-sm">
