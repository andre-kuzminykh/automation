                        <div class="w-12 h-12 md:w-20 md:h-20 bg-white border-2 border-gray-300 rounded-full flex items-center justify-center text-gray-400 mb-2 md:transform md:-translate-y-2 transition-transform">
                            <i class="ph-fill ph-brain text-xl md:text-3xl"></i>
