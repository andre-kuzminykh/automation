                            <div class="w-3 h-3 md:w-5 md:h-5 rounded-full bg-purple-500"></div>
                        </div>
                    </div>
                </div>
                
                <!-- ToT -->
                <div class="bg-gray-50 border border-gray-200 p-6 rounded-2xl shadow-md flex-1 flex flex-col items-center text-center transform md:scale-105 z-10 h-auto min-h-[220px]">
                    <h3 class="font-black text-sm md:text-xl text-gray-900 mb-1">Tree of Thoughts</h3>
                    <p class="text-[8px] md:text-xs text-gray-500 mb-auto">Ветки выбора и гипотезы</p>
                    <div class="flex-1 flex flex-col justify-center w-full min-h-[80px] relative">
                        <svg class="absolute inset-0 w-full h-full" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
                            <line x1="50" y1="20" x2="30" y2="50" stroke="#d1d5db" stroke-width="2"/>
                            <line x1="50" y1="20" x2="70" y2="50" stroke="#d1d5db" stroke-width="2"/>
                            
                            <line x1="30" y1="50" x2="15" y2="80" stroke="#d1d5db" stroke-width="2"/>
                            <line x1="30" y1="50" x2="45" y2="80" stroke="#d1d5db" stroke-width="2"/>
                            
                            <!-- Убрали одну линию и кружок справа для большей чистоты -->
                            <line x1="70" y1="50" x2="85" y2="80" stroke="#d1d5db" stroke-width="2"/>

                            <circle cx="50" cy="20" r="6" fill="#9ca3af"/>
                            <circle cx="30" cy="50" r="6" fill="#9ca3af"/>
                            <circle cx="70" cy="50" r="6" fill="#9ca3af"/>
                            <circle cx="15" cy="80" r="6" fill="#9ca3af"/>
                            <circle cx="45" cy="80" r="6" fill="#9ca3af"/>
                            <circle cx="85" cy="80" r="6" fill="#f97316"/>
                        </svg>
                    </div>
                </div>
                
                <!-- GoT -->
                <div class="bg-purple-50 border border-purple-200 p-6 rounded-2xl shadow-sm flex-1 flex flex-col items-center text-center h-auto min-h-[220px]">
                    <h3 class="font-bold text-sm md:text-xl text-purple-900 mb-1">Graph of Thought</h3>
                    <p class="text-[8px] md:text-xs text-purple-600 mb-auto">Сеть связей (агенты)</p>
                    <div class="flex-1 flex flex-col justify-center w-full min-h-[80px] relative">
                        <svg class="absolute inset-0 w-full h-full pointer-events-none" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid meet">
                            <line x1="50" y1="20" x2="30" y2="50" stroke="#9ca3af" stroke-width="2"/>
                            <line x1="50" y1="20" x2="70" y2="50" stroke="#9ca3af" stroke-width="2"/>
                            <line x1="30" y1="50" x2="70" y2="50" stroke="#9ca3af" stroke-width="2"/>
                            <line x1="30" y1="50" x2="50" y2="80" stroke="#9ca3af" stroke-width="2"/>
                            <line x1="70" y1="50" x2="50" y2="80" stroke="#9ca3af" stroke-width="2"/>
                            
                            <circle cx="50" cy="20" r="6" fill="#9ca3af"/>
                            <circle cx="30" cy="50" r="6" fill="#9ca3af"/>
                            <circle cx="70" cy="50" r="6" fill="#9ca3af"/>
                            <circle cx="50" cy="80" r="6" fill="#9333ea"/>
                        </svg>
                    </div>
                </div>
            </div>

            <div class="text-center font-bold text-[10px] md:text-sm text-gray-500 bg-gray-100 p-3 rounded-lg max-w-3xl mx-auto">
                <span class="text-purple-600">Anything of Thought</span> — Разный тип задачи требует разного паттерна мышления.
            </div>
        </div>
    </div>

    <!-- СЛАЙД 30: Артефакты проекта -->
    <div class="slide-container px-2 md:px-12 opacity-0 pointer-events-none translate-y-8" id="slide-29">
        <div class="content-z max-w-6xl">
