                <div class="bg-white border border-gray-200 p-6 rounded-2xl shadow-sm flex-1 flex flex-col items-center text-center h-auto min-h-[220px]">
                    <h3 class="font-bold text-sm md:text-xl text-gray-800 mb-1">Chain of Thought</h3>
