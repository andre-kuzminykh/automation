                </div>
                
                <div class="bg-gray-50 border border-gray-200 p-3 md:p-4 rounded-xl shadow-sm flex flex-row items-center justify-start text-left">
                    <i class="ph-duotone ph-desktop text-2xl md:text-3xl text-gray-500 shrink-0 mr-3"></i>
