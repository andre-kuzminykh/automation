            <div class="flex flex-col md:flex-row gap-4 md:gap-6 mb-8 md:mb-12 items-start h-auto">
                <!-- Основные -->
                <div class="bg-white border-2 border-purple-400 p-5 md:p-8 rounded-2xl md:rounded-3xl shadow-lg flex-1 flex flex-col z-10 transform md:scale-105 h-auto">
                    <i class="ph-duotone ph-briefcase text-3xl md:text-5xl text-purple-500 mb-3 md:mb-4"></i>
