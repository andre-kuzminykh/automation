        <div class="content-z max-w-5xl h-full flex flex-col justify-center items-center">
            
            <h2 class="text-2xl md:text-4xl font-black mb-6 md:mb-10 text-center leading-tight text-gray-900">
                Агентизация начинается с определения процесса
            </h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-4 max-w-4xl mx-auto w-full mb-8">
                
                <div class="bg-white border border-gray-100 p-3 md:p-4 rounded-xl shadow-sm flex items-center gap-4 relative">
                    <div class="w-8 h-8 md:w-10 md:h-10 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 shrink-0 text-sm">1</div>
                    <span class="font-bold text-[11px] md:text-base text-gray-800">Сначала понимаем, как создается ценность</span>
                </div>
                <div class="bg-white border border-gray-100 p-3 md:p-4 rounded-xl shadow-sm flex items-center gap-4 relative">
                    <div class="w-8 h-8 md:w-10 md:h-10 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 shrink-0 text-sm">2</div>
                    <span class="font-bold text-[11px] md:text-base text-gray-800">Потом строим AS-IS</span>
                </div>
                <div class="bg-white border border-gray-100 p-3 md:p-4 rounded-xl shadow-sm flex items-center gap-4 relative">
                    <div class="w-8 h-8 md:w-10 md:h-10 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 shrink-0 text-sm">3</div>
                    <span class="font-bold text-[11px] md:text-base text-gray-800">Затем находим точки автоматизации</span>
                </div>
                <div class="bg-white border border-gray-100 p-3 md:p-4 rounded-xl shadow-sm flex items-center gap-4 relative">
                    <div class="w-8 h-8 md:w-10 md:h-10 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 shrink-0 text-sm">4</div>
                    <span class="font-bold text-[11px] md:text-base text-gray-800">Проектируем TO-BE</span>
                </div>
                <div class="bg-white border border-gray-100 p-3 md:p-4 rounded-xl shadow-sm flex items-center gap-4 relative">
                    <div class="w-8 h-8 md:w-10 md:h-10 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 shrink-0 text-sm">5</div>
                    <span class="font-bold text-[11px] md:text-base text-gray-800">Определяем новую роль людей</span>
                </div>
                <div class="bg-white border border-gray-100 p-3 md:p-4 rounded-xl shadow-sm flex items-center gap-4 relative">
                    <div class="w-8 h-8 md:w-10 md:h-10 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 shrink-0 text-sm">6</div>
                    <span class="font-bold text-[11px] md:text-base text-gray-800">Формируем граф навыков агента</span>
                </div>
            </div>
            
            <div class="bg-gradient-to-r from-purple-500 to-orange-500 p-[2px] rounded-xl w-full max-w-4xl shadow-md">
                <div class="bg-white px-4 py-4 md:py-5 rounded-[10px] text-center">
                    <p class="text-sm md:text-xl font-black text-gray-900">Разрабатываем, дообучаем, тестируем и внедряем агента</p>
                </div>
            </div>
        </div>
    </div>

    <!-- СЛАЙД 34: Задание -->
    <div class="slide-container px-4 md:px-12 opacity-0 pointer-events-none translate-y-8" id="slide-33">
        <div class="content-z max-w-2xl flex flex-col h-full justify-center mx-auto">
            
            <h2 class="text-3xl md:text-5xl font-black text-gray-900 leading-tight mb-8 text-center">Задание <span class="text-transparent bg-clip-text bg-gradient-to-r from-purple-500 to-orange-500">на семинар</span></h2>
            
            <div class="bg-white border border-gray-200 p-6 md:p-10 rounded-2xl md:rounded-3xl shadow-xl w-full mx-auto">
                <div class="flex flex-col gap-3 md:gap-4 relative">
                    
                    <div class="flex items-center gap-4 bg-white p-3 rounded-xl border border-gray-100 hover:bg-gray-50 transition-colors">
                        <i class="ph-duotone ph-target text-2xl text-gray-400 shrink-0"></i>
                        <h3 class="font-bold text-sm md:text-lg text-gray-800">Выбрать свой бизнес-процесс (RUN)</h3>
                    </div>
                    
                    <div class="flex items-center gap-4 bg-white p-3 rounded-xl border border-gray-100 hover:bg-gray-50 transition-colors">
                        <i class="ph-duotone ph-git-branch text-2xl text-gray-400 shrink-0"></i>
                        <h3 class="font-bold text-sm md:text-lg text-gray-800">Описать текущее состояние (AS-IS)</h3>
                    </div>
                    
                    <div class="flex items-center gap-4 bg-white p-3 rounded-xl border border-gray-100 hover:bg-purple-50 transition-colors">
                        <i class="ph-duotone ph-crosshair text-2xl text-purple-400 shrink-0"></i>
                        <h3 class="font-bold text-sm md:text-lg text-gray-800">Найти точки принятия решений (автоматизации)</h3>
                    </div>
                    
                    <div class="flex items-center gap-4 bg-white p-3 rounded-xl border border-gray-100 hover:bg-orange-50 transition-colors">
                        <i class="ph-duotone ph-git-merge text-2xl text-orange-400 shrink-0"></i>
                        <h3 class="font-bold text-sm md:text-lg text-gray-800">Спроектировать TO-BE</h3>
                    </div>

                    <div class="flex items-center gap-4 bg-white p-3 rounded-xl border border-gray-100 hover:bg-orange-50 transition-colors">
                        <i class="ph-duotone ph-user-switch text-2xl text-gray-400 shrink-0"></i>
                        <h3 class="font-bold text-sm md:text-lg text-gray-800">Определить роль человека</h3>
                    </div>

                    <div class="flex items-center gap-4 bg-gray-50 border border-gray-200 p-3 rounded-xl">
                        <i class="ph-duotone ph-graph text-2xl text-purple-500 shrink-0"></i>
                        <h3 class="font-bold text-sm md:text-lg text-gray-800">Сформировать граф навыков ИИ-агента</h3>
                    </div>
                </div>
            </div>

            <div class="mt-8 md:mt-10 text-center text-gray-600 text-[10px] md:text-base mx-auto px-4">
                Пройдите тот же путь, о котором мы говорили на лекции,<br>
                <b class="text-gray-900 mt-1 inline-block">на своём реальном процессе</b>.
            </div>
        </div>
    </div>

<script>
    document.addEventListener('DOMContentLoaded', () => {
        const totalSlides = 34; // Обновлено количество слайдов
        let currentSlide = 0;
        const progressBar = document.getElementById('progress-bar');
        const body = document.body;
        const params = new URLSearchParams(window.location.search);
        const exportMode = 
            params.has('pdf') || 
            params.get('mode') === 'pdf' || 
            window.location.hash === '#pdf';

        function updateProgress() {
            if (!progressBar) return;
            const progress = ((currentSlide + 1) / totalSlides) * 100;
            progressBar.style.width = `${progress}%`;
        }

        function updateSlides() {
            for (let i = 0; i < totalSlides; i++) {
                const slide = document.getElementById(`slide-${i}`);
                if (!slide) continue;

                if (i === currentSlide) {
                    slide.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-8', '-translate-y-8');
                    slide.classList.add('opacity-100', 'translate-y-0');
                } else if (i < currentSlide) {
                    slide.classList.remove('opacity-100', 'translate-y-0', 'translate-y-8');
                    slide.classList.add('opacity-0', 'pointer-events-none', '-translate-y-8');
                } else {
                    slide.classList.remove('opacity-100', 'translate-y-0', '-translate-y-8');
                    slide.classList.add('opacity-0', 'pointer-events-none', 'translate-y-8');
                }
            }
            updateProgress();
        }

        function showAllSlidesForPdf() {
            body.classList.add('pdf-export-mode');
            for (let i = 0; i < totalSlides; i++) {
                const slide = document.getElementById(`slide-${i}`);
                if (!slide) continue;
                slide.classList.remove('opacity-0', 'pointer-events-none', 'translate-y-8', '-translate-y-8');
                slide.classList.add('opacity-100');
                slide.style.transform = 'none';
                slide.style.pointerEvents = 'auto';
            }
            if (progressBar) progressBar.style.width = '100%';
        }

        function restoreInteractiveMode() {
            body.classList.remove('pdf-export-mode');
            for (let i = 0; i < totalSlides; i++) {
                const slide = document.getElementById(`slide-${i}`);
                if (!slide) continue;
                slide.style.transform = '';
                slide.style.pointerEvents = '';
            }
            updateSlides();
        }

        function nextSlide() {
            if (currentSlide < totalSlides - 1) {
                currentSlide++;
                updateSlides();
            }
        }

        function prevSlide() {
            if (currentSlide > 0) {
                currentSlide--;
                updateSlides();
            }
        }

        window.addEventListener('beforeprint', () => { showAllSlidesForPdf(); });
        window.addEventListener('afterprint', () => { if (!exportMode) restoreInteractiveMode(); });

        if (exportMode) {
            showAllSlidesForPdf();
            return;
        }

        window.addEventListener('keydown', (e) => {
            if (['ArrowRight', ' ', 'Enter', 'PageDown'].includes(e.key)) {
                nextSlide();
            } else if (['ArrowLeft', 'PageUp', 'Backspace'].includes(e.key)) {
                prevSlide();
            }
        });

        window.addEventListener('mousedown', (e) => {
            // Игнорируем клики по ссылкам и кнопкам
            if(e.target.closest('a') || e.target.closest('button')) return;
            if (e.button === 0) nextSlide();
            if (e.button === 2) prevSlide();
        });

        window.addEventListener('contextmenu', e => e.preventDefault());

        let touchStartX = 0;
        window.addEventListener('touchstart', e => {
            touchStartX = e.changedTouches[0].screenX;
        }, { passive: true });

        window.addEventListener('touchend', e => {
            const touchEndX = e.changedTouches[0].screenX;
            const swipeThreshold = 50;
            if (touchStartX - touchEndX > swipeThreshold) {
                nextSlide();
            } else if (touchEndX - touchStartX > swipeThreshold) {
                prevSlide();
            }
        }, { passive: true });

        updateSlides();
    });
</script>
    
</body>
</html>
