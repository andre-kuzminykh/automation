    </div>

    <!-- СЛАЙД 26: Когнитивные функции агента -->
    <div class="slide-container px-2 md:px-12 opacity-0 pointer-events-none translate-y-8" id="slide-25">
        <div class="content-z max-w-6xl">
            <h2 class="text-2xl md:text-5xl font-black mb-4 text-center text-gray-900">Когнитивная <span class="gradient-text">функция</span></h2>
            <p class="text-center text-[10px] md:text-sm text-gray-500 mb-8 md:mb-12">Каждое решение человека можно представить как функцию для ИИ</p>
            
            <div class="flex flex-col md:flex-row items-center justify-center gap-2 md:gap-4 mb-8 md:mb-12 w-full max-w-5xl mx-auto h-auto md:h-40">
                <!-- Вход -->
                <div class="bg-white border border-gray-200 p-3 md:p-5 rounded-xl shadow-sm flex-1 w-full h-full flex flex-col justify-center text-center">
                    <span class="text-[8px] md:text-xs font-bold text-gray-400 block mb-1">Данные</span>
