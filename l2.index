    <!-- СЛАЙД 12: Когнитивный анализ процесса -->
    <div class="slide-container px-4 md:px-12 opacity-0 pointer-events-none translate-y-8" id="slide-11">
        <div class="content-z max-w-6xl">
            <h2 class="text-2xl md:text-5xl font-black mb-2 text-center text-gray-900">Когнитивный <span class="gradient-text">анализ</span></h2>
            <p class="text-center text-gray-600 text-[10px] md:text-base mb-8 md:mb-12">Процесс состоит не только из действий, но и из решений</p>
            
            <div class="flex flex-col md:flex-row gap-4 md:gap-8 justify-center items-stretch mb-8 md:mb-12">
                <!-- Действия -->
                <div class="bg-white border border-gray-200 p-6 md:p-10 rounded-2xl md:rounded-3xl shadow-sm w-full md:w-[40%] flex flex-col items-center text-center">
