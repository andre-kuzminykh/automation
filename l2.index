                <div class="bg-gradient-to-r from-purple-50 to-orange-50 border border-purple-200 p-4 md:p-6 rounded-xl shadow-sm flex items-start gap-3 md:gap-4">
                    <div class="bg-white p-2 rounded-lg text-purple-600 shadow-sm shrink-0"><i class="ph-duotone ph-network text-xl md:text-3xl"></i></div>
                    <div>
                        <h4 class="font-bold text-[11px] md:text-lg text-gray-900 mb-1">База мультиагентности</h4>
                        <p class="text-[9px] md:text-sm text-gray-600 leading-tight">Основа для взаимодействия нескольких агентов.</p>
                    </div>
                </div>
            </div>

            <div class="text-center bg-gray-900 text-white p-3 md:p-4 rounded-lg max-w-2xl mx-auto shadow-md">
                <p class="text-xs md:text-lg font-bold tracking-wide">Дизайн компании как <span class="text-orange-400">мультиагентной системы</span></p>
            </div>
        </div>
    </div>

    <!-- СЛАЙД 29: Паттерны рассуждений ИИ -->
    <div class="slide-container px-2 md:px-12 opacity-0 pointer-events-none translate-y-8" id="slide-28">
        <div class="content-z max-w-6xl h-full flex flex-col justify-center">
