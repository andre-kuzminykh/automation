        <div class="content-z max-w-5xl">
            <h2 class="text-2xl md:text-5xl font-black mb-8 md:mb-12 text-center text-gray-900">Зачем нужен <span class="gradient-text">граф</span></h2>
            
            <div class="grid grid-cols-1 md:grid-cols-2 gap-3 md:gap-6 mb-8 md:mb-12">
                <div class="bg-purple-50/50 border border-purple-100 p-4 md:p-6 rounded-xl shadow-sm flex items-start gap-3 md:gap-4">
