<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>Лекция 2: От AS-IS к TO-BE</title>
    <!-- Tailwind CSS -->
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Google Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;700;900&display=swap" rel="stylesheet">
    <!-- Phosphor Icons -->
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        sans: ['Inter', 'sans-serif'],
                    },
                    colors: {
                        brand: {
                            purple: '#7c3aed',
                            orange: '#f97316',
                        }
                    }
                }
            }
        }
    </script>

<style>
    html { background: #ffffff !important; }
    body {
        user-select: none;
        overflow: hidden;
        background-color: #ffffff !important;
        margin: 0;
        width: 100vw;
        height: 100vh;
    }

    .slide-container {
        transition: opacity 0.4s ease-in-out, transform 0.4s ease-in-out;
        position: absolute;
        top: 0; left: 0; width: 100%; height: 100%;
        display: flex; flex-direction: column; justify-content: center;
        overflow-y: auto; overflow-x: hidden; background: #ffffff;
        -ms-overflow-style: none; scrollbar-width: none;
    }
    .slide-container::-webkit-scrollbar { display: none; }

    .content-z {
        position: relative; z-index: 10; margin: auto; width: 100%;
        padding-top: 1rem; padding-bottom: 1.5rem;
    }

    @media (min-width: 768px) {
        .content-z { padding-top: 2rem; padding-bottom: 3rem; }
    }

    .gradient-text {
        background-clip: text; -webkit-background-clip: text; -webkit-text-fill-color: transparent;
        background-image: linear-gradient(to right, #7c3aed, #f97316);
    }
    .gradient-bg { background-image: linear-gradient(135deg, #7c3aed, #f97316); }

    .bg-glow-1 {
        position: absolute; top: -20%; left: -10%; width: 80vw; height: 80vw; max-width: 800px; max-height: 800px;
        background: radial-gradient(circle, rgba(124,58,237,0.03) 0%, rgba(255,255,255,0) 70%);
        z-index: 0; pointer-events: none;
    }
    .bg-glow-2 {
        position: absolute; bottom: -20%; right: -10%; width: 60vw; height: 60vw; max-width: 600px; max-height: 600px;
        background: radial-gradient(circle, rgba(249,115,22,0.03) 0%, rgba(255,255,255,0) 70%);
        z-index: 0; pointer-events: none;
    }

    @keyframes pulse-slow {
        0%, 100% { opacity: 1; transform: scale(1); }
        50% { opacity: 0.8; transform: scale(1.05); }
    }
    .animate-pulse-slow { animation: pulse-slow 4s ease-in-out infinite; }

    /* PDF Mode */
    body.pdf-export-mode { overflow: auto !important; height: auto !important; }
    body.pdf-export-mode .bg-glow-1, body.pdf-export-mode .bg-glow-2, body.pdf-export-mode #progress-container { display: none !important; }
    body.pdf-export-mode .slide-container {
        position: relative !important; width: 100% !important; min-height: 100vh; height: auto !important;
        opacity: 1 !important; transform: none !important; pointer-events: auto !important; overflow: visible !important;
        page-break-after: always; break-after: page; break-inside: avoid;
    }
    @page { size: A4 landscape; margin: 10mm; }
    @media print {
        html, body { overflow: visible !important; height: auto !important; -webkit-print-color-adjust: exact; print-color-adjust: exact; }
        .bg-glow-1, .bg-glow-2, #progress-container { display: none !important; }
        .slide-container {
            position: relative !important; width: 100% !important; min-height: 100vh; height: auto !important;
            opacity: 1 !important; transform: none !important; pointer-events: auto !important; overflow: visible !important;
            page-break-after: always; break-after: page; break-inside: avoid;
        }
    }
</style>
</head>
<body class="text-gray-900 font-sans">

    <!-- Декоративный фон -->
    <div class="bg-glow-1"></div>
    <div class="bg-glow-2"></div>

    <!-- Индикатор прогресса -->
    <div id="progress-container" class="absolute bottom-0 left-0 h-1.5 bg-gray-100 w-full z-50">
        <div id="progress-bar" class="h-full gradient-bg w-0 transition-all duration-300"></div>
    </div>

    <!-- СЛАЙД 1: Титульный -->
    <div class="slide-container px-4 md:px-12 opacity-100 translate-y-0" id="slide-0">
        <div class="content-z text-center w-full max-w-6xl px-4 flex flex-col items-center justify-center h-full">
            <div class="bg-gradient-to-r from-purple-50 to-orange-50 border border-purple-100 rounded-xl p-3 md:p-5 max-w-2xl w-full shadow-sm mb-6 md:mb-10">
                <p class="text-purple-600 font-semibold uppercase tracking-widest text-[10px] md:text-xs mb-1 md:mb-1.5"><i class="ph-fill ph-book-open"></i> Лекция 2</p>
                <h2 class="text-sm md:text-xl font-bold text-gray-800 leading-tight">От AS-IS к TO-BE: моделирование процессов и анализ точек автоматизации</h2>
            </div>

            <h1 class="text-4xl md:text-6xl lg:text-[80px] font-black mb-8 md:mb-12 leading-[1.05] tracking-tight text-gray-900 drop-shadow-sm flex flex-col items-center">
                <span>Автоматизация</span>
                <span>бизнес-процессов</span>
                <span class="gradient-text">с помощью ИИ-агентов</span>
            </h1>
            
            <div class="w-24 h-1 gradient-bg rounded-full mt-4 opacity-50"></div>
            <p class="text-gray-500 font-medium mt-4 text-sm md:text-lg">Андрей Кузьминых</p>
        </div>
    </div>

    <!-- СЛАЙД 2: О чём эта лекция (Roadmap) -->
    <div class="slide-container px-4 md:px-12 opacity-0 pointer-events-none translate-y-8" id="slide-1">
        <div class="content-z max-w-5xl">
            <h2 class="text-2xl md:text-5xl font-black mb-8 md:mb-12 text-center text-gray-900">О чём эта <span class="gradient-text">лекция</span></h2>
            
            <div class="relative border-l-2 border-gray-200 ml-4 md:ml-12 space-y-4 md:space-y-6 max-w-3xl mx-auto">
                <div class="relative pl-6 md:pl-10 flex items-center">
                    <div class="absolute -left-[9px] w-4 h-4 bg-white border-2 border-gray-300 rounded-full"></div>
                    <div class="w-6 h-6 md:w-8 md:h-8 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 text-[10px] md:text-sm mr-3 shrink-0">1</div>
                    <h3 class="text-sm md:text-xl font-bold text-gray-800">Что такое бизнес-процесс</h3>
                </div>
                <div class="relative pl-6 md:pl-10 flex items-center">
                    <div class="absolute -left-[9px] w-4 h-4 bg-white border-2 border-gray-300 rounded-full"></div>
                    <div class="w-6 h-6 md:w-8 md:h-8 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 text-[10px] md:text-sm mr-3 shrink-0">2</div>
                    <h3 class="text-sm md:text-xl font-bold text-gray-800">Как описывать процесс в модели AS-IS</h3>
                </div>
                <div class="relative pl-6 md:pl-10 flex items-center">
                    <div class="absolute -left-[9px] w-4 h-4 bg-white border-2 border-gray-300 rounded-full"></div>
                    <div class="w-6 h-6 md:w-8 md:h-8 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 text-[10px] md:text-sm mr-3 shrink-0">3</div>
                    <h3 class="text-sm md:text-xl font-bold text-gray-800">Как находить точки автоматизации</h3>
                </div>
                <div class="relative pl-6 md:pl-10 flex items-center">
                    <div class="absolute -left-[9px] w-4 h-4 bg-white border-2 border-gray-300 rounded-full"></div>
                    <div class="w-6 h-6 md:w-8 md:h-8 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 text-[10px] md:text-sm mr-3 shrink-0">4</div>
                    <h3 class="text-sm md:text-xl font-bold text-gray-800">Как проектировать целевой процесс TO-BE</h3>
                </div>
                <div class="relative pl-6 md:pl-10 flex items-center">
                    <div class="absolute -left-[9px] w-4 h-4 bg-white border-2 border-gray-300 rounded-full"></div>
                    <div class="w-6 h-6 md:w-8 md:h-8 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 text-[10px] md:text-sm mr-3 shrink-0">5</div>
                    <h3 class="text-sm md:text-xl font-bold text-gray-800">Как определить новую роль человека</h3>
                </div>
                <div class="relative pl-6 md:pl-10 flex items-center">
                    <div class="absolute -left-[9px] w-4 h-4 bg-white border-2 border-gray-300 rounded-full"></div>
                    <div class="w-6 h-6 md:w-8 md:h-8 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 text-[10px] md:text-sm mr-3 shrink-0">6</div>
                    <h3 class="text-sm md:text-xl font-bold text-gray-800">Как описывать навыки ИИ-агента</h3>
                </div>
                <div class="relative pl-6 md:pl-10 flex items-center">
                    <div class="absolute -left-[9px] w-4 h-4 bg-white border-2 border-gray-300 rounded-full"></div>
                    <div class="w-6 h-6 md:w-8 md:h-8 bg-gray-100 rounded-full flex items-center justify-center font-bold text-gray-500 text-[10px] md:text-sm mr-3 shrink-0">7</div>
                    <h3 class="text-sm md:text-xl font-bold text-gray-800">Как запускать проект автоматизации</h3>
                </div>
                <div class="relative pl-6 md:pl-10 mt-6 md:mt-8">
                    <div class="absolute -left-[13px] md:-left-[15px] top-1/2 transform -translate-y-1/2 w-6 h-6 md:w-7 md:h-7 bg-white border-4 border-orange-500 rounded-full z-10"></div>
                    <div class="bg-gradient-to-r from-orange-50 to-purple-50 border-2 border-orange-200 p-3 md:p-5 rounded-xl md:rounded-2xl shadow-md relative overflow-hidden flex items-center">
                        <div class="absolute top-0 right-0 bg-orange-500 text-white text-[8px] md:text-xs font-bold px-2 py-1 rounded-bl-lg">ПРАКТИКА</div>
                        <div class="w-6 h-6 md:w-8 md:h-8 bg-orange-500 rounded-full flex items-center justify-center font-bold text-white text-[10px] md:text-sm mr-3 shrink-0">8</div>
                        <div>
                            <h3 class="text-base md:text-2xl font-black text-gray-900 leading-tight">Семинар: редизайн своего бизнес-процесса</h3>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- СЛАЙД 3: Что такое бизнес-процесс -->
    <div class="slide-container px-4 md:px-12 opacity-0 pointer-events-none translate-y-8" id="slide-2">
        <div class="content-z max-w-6xl flex flex-col md:flex-row gap-6 md:gap-12 items-center h-full">
            <div class="w-full md:w-[55%] flex flex-col justify-center">
                <h2 class="text-2xl md:text-5xl font-black mb-6 md:mb-8 text-gray-900 leading-tight">Что такое <span class="gradient-text">бизнес-процесс</span></h2>
                <div class="text-[14px] md:text-2xl text-gray-700 leading-relaxed border-l-4 border-purple-300 pl-4 md:pl-6 py-2">
                    Это <b>устойчивая последовательность действий</b>, которая <b>преобразует входные данные в результат</b> и <b>создаёт ценность</b> для клиента (внутреннего или внешнего).
                </div>
            </div>
            
            <div class="w-full md:w-[45%]">
                <div class="grid grid-cols-2 gap-3 md:gap-4">
                    <div class="bg-white border border-gray-200 p-3 rounded-xl shadow-sm relative overflow-hidden flex items-center gap-2">
                        <div class="absolute top-0 left-0 w-full h-1 bg-purple-500"></div>
                        <div class="w-2 h-2 rounded-full bg-purple-500"></div>
                        <h4 class="font-bold text-gray-800 text-sm md:text-base">Цель процесса</h4>
                    </div>
                    <div class="bg-white border border-gray-200 p-3 rounded-xl shadow-sm relative overflow-hidden flex items-center gap-2">
                        <div class="absolute top-0 left-0 w-full h-1 bg-orange-400"></div>
                        <div class="w-2 h-2 rounded-full bg-orange-400"></div>
                        <h4 class="font-bold text-gray-800 text-sm md:text-base">Вход</h4>
                    </div>
                    <div class="bg-white border border-gray-200 p-3 rounded-xl shadow-sm relative overflow-hidden flex items-center gap-2">
                        <div class="absolute top-0 left-0 w-full h-1 bg-gray-400"></div>
                        <div class="w-2 h-2 rounded-full bg-gray-400"></div>
                        <h4 class="font-bold text-gray-800 text-sm md:text-base">Операция</h4>
                    </div>
                    <div class="bg-white border border-gray-200 p-3 rounded-xl shadow-sm relative overflow-hidden flex items-center gap-2">
                        <div class="absolute top-0 left-0 w-full h-1 bg-green-500"></div>
                        <div class="w-2 h-2 rounded-full bg-green-500"></div>
                        <h4 class="font-bold text-gray-800 text-sm md:text-base">Выход</h4>
                    </div>
                    <div class="bg-white border border-gray-200 p-3 rounded-xl shadow-sm relative overflow-hidden flex items-center gap-2">
                        <div class="absolute top-0 left-0 w-full h-1 bg-blue-400"></div>
                        <div class="w-2 h-2 rounded-full bg-blue-400"></div>
                        <h4 class="font-bold text-gray-800 text-sm md:text-base">Артефакт</h4>
                    </div>
                    <div class="bg-white border border-gray-200 p-3 rounded-xl shadow-sm relative overflow-hidden flex items-center gap-2">
                        <div class="absolute top-0 left-0 w-full h-1 bg-purple-400"></div>
                        <div class="w-2 h-2 rounded-full bg-purple-400"></div>
                        <h4 class="font-bold text-gray-800 text-sm md:text-base">Участник</h4>
                    </div>
                    <div class="bg-white border border-gray-200 p-3 rounded-xl shadow-sm relative overflow-hidden col-span-2 flex items-center justify-center gap-2">
                        <div class="absolute top-0 left-0 w-full h-1 bg-orange-500"></div>
                        <div class="w-2 h-2 rounded-full bg-orange-500"></div>
                        <h4 class="font-bold text-gray-800 text-sm md:text-base">Метрика</h4>
                    </div>
                </div>
            </div>

            <div class="absolute bottom-6 md:bottom-12 left-0 w-full px-4 md:px-12">
                <div class="bg-orange-50 border border-orange-200 py-3 md:py-5 px-4 md:px-8 rounded-xl max-w-4xl mx-auto text-center shadow-sm">
                    <p class="text-orange-900 font-bold text-[12px] md:text-xl"><i class="ph-fill ph-warning-circle text-orange-500 align-middle mr-2"></i> Если нет метрики — процессом нельзя управлять</p>
                </div>
            </div>
        </div>
    </div>

    <!-- СЛАЙД 4: Процесс как поток данных -->
    <div class="slide-container px-4 md:px-12 opacity-0 pointer-events-none translate-y-8" id="slide-3">
        <div class="content-z max-w-6xl text-center">
            <h2 class="text-2xl md:text-5xl font-black mb-12 md:mb-20 text-gray-900">Процесс как <span class="gradient-text">поток данных</span></h2>
            
            <div class="flex flex-col md:flex-row items-center justify-center gap-2 md:gap-4 mb-12">
                <!-- Вход -->
                <div class="bg-gray-50 border border-gray-200 p-4 md:p-6 rounded-2xl w-full md:w-48 shadow-sm flex flex-col items-center">
                    <i class="ph-duotone ph-file-arrow-down text-3xl md:text-5xl text-gray-400 mb-2"></i>
                    <h4 class="font-bold text-gray-900 text-sm md:text-lg">Вход</h4>
                    <span class="text-[10px] md:text-xs text-gray-500 mt-1">данные</span>
                </div>
                <i class="ph-bold ph-arrow-right text-2xl md:text-4xl text-gray-300 hidden md:block"></i>
                <i class="ph-bold ph-arrow-down text-2xl text-gray-300 md:hidden"></i>
                
                <!-- Операция -->
                <div class="bg-purple-50 border border-purple-200 p-4 md:p-6 rounded-2xl w-full md:w-48 shadow-sm flex flex-col items-center">
                    <i class="ph-duotone ph-gear text-3xl md:text-5xl text-purple-500 mb-2"></i>
                    <h4 class="font-bold text-gray-900 text-sm md:text-lg">Операция</h4>
                    <span class="text-[10px] md:text-xs text-purple-600 mt-1">действие</span>
                </div>
                <i class="ph-bold ph-arrow-right text-2xl md:text-4xl text-gray-300 hidden md:block"></i>
                <i class="ph-bold ph-arrow-down text-2xl text-gray-300 md:hidden"></i>

                <!-- Выход -->
                <div class="bg-gray-50 border border-gray-200 p-4 md:p-6 rounded-2xl w-full md:w-48 shadow-sm flex flex-col items-center">
                    <i class="ph-duotone ph-file-arrow-up text-3xl md:text-5xl text-gray-400 mb-2"></i>
                    <h4 class="font-bold text-gray-900 text-sm md:text-lg">Выход</h4>
                    <span class="text-[10px] md:text-xs text-gray-500 mt-1">результат</span>
                </div>
                <i class="ph-bold ph-arrow-right text-2xl md:text-4xl text-gray-300 hidden md:block"></i>
                <i class="ph-bold ph-arrow-down text-2xl text-gray-300 md:hidden"></i>

                <!-- Ценность -->
                <div class="bg-orange-50 border border-orange-200 p-4 md:p-6 rounded-2xl w-full md:w-48 shadow-md flex flex-col items-center">
                    <i class="ph-duotone ph-star text-3xl md:text-5xl text-orange-500 mb-2"></i>
                    <h4 class="font-bold text-gray-900 text-sm md:text-lg">Ценность</h4>
                    <span class="text-[10px] md:text-xs text-orange-600 mt-1">усиление</span>
                </div>
            </div>

            <div class="flex flex-wrap justify-center gap-3 md:gap-4 max-w-5xl mx-auto">
                <div class="bg-white px-5 py-3 border border-gray-200 rounded-xl shadow-sm text-[10px] md:text-sm font-medium text-gray-700">Процесс — не просто действия людей и агентов, а <b>поток данных</b></div>
                <div class="bg-white px-5 py-3 border border-gray-200 rounded-xl shadow-sm text-[10px] md:text-sm font-medium text-gray-700"><b>Выход</b> одного шага становится <b>входом</b> следующего</div>
                <div class="bg-white px-5 py-3 border border-gray-200 rounded-xl shadow-sm text-[10px] md:text-sm font-medium text-gray-700">Автоматизация <b>ускоряет, упрощает и усиливает</b> поток создания ценности</div>
                <div class="bg-white px-5 py-3 border border-gray-200 rounded-xl shadow-sm text-[10px] md:text-sm font-medium text-gray-700">Нужно смотреть на процесс как на <b>систему преобразования данных</b></div>
            </div>
        </div>
    </div>

    <!-- СЛАЙД 5: Почему автоматизация начинается с БП -->
    <div class="slide-container px-4 md:px-12 opacity-0 pointer-events-none translate-y-8" id="slide-4">
        <div class="content-z max-w-6xl flex flex-col justify-center h-full">
            <h2 class="text-2xl md:text-4xl font-black mb-8 md:mb-12 text-gray-900 text-center">Почему автоматизация начинается <br class="hidden md:block">с <span class="gradient-text">бизнес-процесса</span></h2>
            
            <div class="flex flex-col md:flex-row gap-6 md:gap-12 items-center">
                <!-- Левая зона: Проблема -->
                <div class="w-full md:w-1/2 space-y-3 md:space-y-4">
                    <div class="bg-gray-50 border border-gray-200 p-4 rounded-xl flex items-start gap-3">
                        <i class="ph-fill ph-x-circle text-gray-400 text-xl md:text-2xl shrink-0 mt-0.5"></i>
                        <p class="text-xs md:text-base text-gray-700 font-medium leading-tight">ИИ нельзя внедрять в хаотичный процесс</p>
                    </div>
                    <div class="bg-gray-50 border border-gray-200 p-4 rounded-xl flex items-start gap-3">
                        <i class="ph-fill ph-ruler text-gray-400 text-xl md:text-2xl shrink-0 mt-0.5"></i>
                        <p class="text-xs md:text-base text-gray-700 font-medium leading-tight">Автоматизировать можно только то, что описано, измерено и управляемо</p>
                    </div>
                    <div class="bg-gray-50 border border-gray-200 p-4 rounded-xl flex items-start gap-3">
                        <i class="ph-fill ph-blueprint text-gray-400 text-xl md:text-2xl shrink-0 mt-0.5"></i>
                        <p class="text-xs md:text-base text-gray-700 font-medium leading-tight">Бизнес-процесс показывает, как компания создаёт ценность</p>
                    </div>
                </div>

                <div class="hidden md:flex justify-center shrink-0">
                    <i class="ph-bold ph-arrow-right text-4xl text-purple-300"></i>
                </div>

                <!-- Правая зона: Решение -->
                <div class="w-full md:w-1/2 bg-gradient-to-br from-purple-50 to-orange-50 border border-purple-100 p-6 md:p-8 rounded-2xl shadow-md">
                    <h3 class="font-bold text-gray-900 text-sm md:text-xl mb-6">Именно процесс позволяет увидеть:</h3>
                    <div class="space-y-4 md:space-y-6">
                        <div class="flex items-center gap-4">
                            <div class="bg-white p-2 rounded-lg shadow-sm text-purple-500"><i class="ph-fill ph-hourglass-high text-xl md:text-2xl"></i></div>
                            <span class="text-sm md:text-lg font-bold text-gray-800">где теряется время</span>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="bg-white p-2 rounded-lg shadow-sm text-orange-500"><i class="ph-fill ph-warning text-xl md:text-2xl"></i></div>
                            <span class="text-sm md:text-lg font-bold text-gray-800">где возникают ошибки</span>
                        </div>
                        <div class="flex items-center gap-4">
                            <div class="bg-white p-2 rounded-lg shadow-sm text-green-500"><i class="ph-fill ph-robot text-xl md:text-2xl"></i></div>
                            <span class="text-sm md:text-lg font-bold text-gray-800">где можно передать работу ИИ</span>
                        </div>
                    </div>
                </div>
            </div>

            <div class="mt-8 md:mt-12 bg-gray-900 text-white rounded-xl md:rounded-2xl p-4 md:p-6 text-center shadow-lg">
                <p class="text-xs md:text-xl font-bold tracking-wide">Без понимания процессов автоматизация превращается <br class="hidden md:block">в <span class="text-orange-400">хаотичное внедрение технологий</span></p>
            </div>
        </div>
    </div>

    <!-- СЛАЙД 6: RUN - CHANGE - DISRUPT -->
    <div class="slide-container px-4 md:px-12 opacity-0 pointer-events-none translate-y-8" id="slide-5">
        <div class="content-z max-w-6xl">
            <h2 class="text-2xl md:text-5xl font-black mb-2 md:mb-4 text-center text-gray-900"><span class="gradient-text">RUN</span> — CHANGE — DISRUPT</h2>
            <p class="text-center text-gray-500 text-xs md:text-sm mb-8 md:mb-12">Три уровня деятельности компании</p>
            
            <div class="flex flex-col md:flex-row gap-4 md:gap-6 mb-8 md:mb-10 items-start">
                <!-- RUN -->
                <div class="bg-white border-2 border-purple-500 p-4 md:p-8 rounded-2xl md:rounded-3xl shadow-lg relative flex-1 flex flex-col items-center text-center transform md:scale-105 z-10 w-full h-auto">
                    <div class="absolute -top-3 md:-top-4 left-1/2 transform -translate-x-1/2 bg-purple-500 text-white text-[8px] md:text-xs font-bold px-3 py-1 rounded-full uppercase whitespace-nowrap">основной фокус автоматизации</div>
                    <div class="text-purple-500 mb-3 md:mb-6 mt-2 md:mt-0"><i class="ph-fill ph-gear text-4xl md:text-6xl"></i></div>
                    <h3 class="font-black text-xl md:text-3xl text-gray-900 mb-1 md:mb-2">RUN</h3>
                    <p class="text-[10px] md:text-sm font-medium text-gray-700 mb-4">операционная деятельность</p>
                    <div class="mt-2 md:mt-4 bg-purple-50 px-3 py-2 rounded-lg w-full">
                        <span class="text-[9px] md:text-xs text-purple-700 font-bold uppercase">Низкая неопределённость</span>
                    </div>
                </div>
                
                <!-- CHANGE -->
                <div class="bg-gray-50 border border-orange-200 p-4 md:p-8 rounded-2xl md:rounded-3xl shadow-sm flex-1 flex flex-col items-center text-center w-full h-auto">
                    <div class="text-orange-400 mb-3 md:mb-6"><i class="ph-fill ph-arrows-merge text-4xl md:text-6xl"></i></div>
                    <h3 class="font-black text-xl md:text-3xl text-gray-900 mb-1 md:mb-2">CHANGE</h3>
                    <p class="text-[10px] md:text-sm font-medium text-gray-600 mb-4">проекты изменений</p>
                    <div class="mt-2 md:mt-4 bg-orange-50 px-3 py-2 rounded-lg w-full">
                        <span class="text-[9px] md:text-xs text-orange-600 font-bold uppercase">Средняя неопределённость</span>
                    </div>
                </div>
                
                <!-- DISRUPT -->
                <div class="bg-gray-50 border border-gray-200 p-4 md:p-8 rounded-2xl md:rounded-3xl shadow-sm flex-1 flex flex-col items-center text-center opacity-80 w-full h-auto">
                    <div class="text-gray-400 mb-3 md:mb-6"><i class="ph-fill ph-rocket text-4xl md:text-6xl"></i></div>
                    <h3 class="font-black text-xl md:text-3xl text-gray-900 mb-1 md:mb-2">DISRUPT</h3>
                    <p class="text-[10px] md:text-sm font-medium text-gray-500 mb-4">исследования и новые модели</p>
                    <div class="mt-2 md:mt-4 bg-gray-100 px-3 py-2 rounded-lg w-full">
                        <span class="text-[9px] md:text-xs text-gray-500 font-bold uppercase">Высокая неопределённость</span>
                    </div>
                </div>
            </div>

            <div class="bg-purple-900 text-white px-6 py-3 md:py-4 rounded-xl text-center max-w-3xl mx-auto shadow-md mt-6">
                <p class="text-sm md:text-xl font-bold">Автоматизацию обычно начинают с <span class="text-purple-300">RUN-процессов</span></p>
            </div>
        </div>
    </div>

    <!-- СЛАЙД 7: Процесс как часть архитектуры -->
