                <i class="ph-bold ph-arrow-right text-gray-300 text-2xl hidden md:block shrink-0"></i>
                <i class="ph-bold ph-arrow-down text-gray-300 text-2xl md:hidden shrink-0"></i>
                
                <!-- Метрика -->
