    <!-- СЛАЙД 27: Граф навыков -->
    <div class="slide-container px-4 md:px-12 opacity-0 pointer-events-none translate-y-8" id="slide-26">
        <div class="content-z max-w-6xl">
            <h2 class="text-2xl md:text-5xl font-black mb-6 md:mb-12 text-center text-gray-900">Граф <span class="gradient-text">навыков ИИ-агента</span></h2>
            
            <div class="relative w-full max-w-[600px] h-64 md:h-80 mx-auto flex items-center justify-center mb-6 md:mb-8">
                <!-- SVG Lines First so they are behind -->
                <svg class="absolute inset-0 w-full h-full z-0" viewBox="0 0 100 100" preserveAspectRatio="none">
                    <!-- Agent is at (50, 50) -->
                    <!-- N1: 50, 15 -->
                    <line x1="50" y1="50" x2="50" y2="15" stroke="#d1d5db" stroke-width="0.5"/>
                    <!-- N2: 85, 50 -->
                    <line x1="50" y1="50" x2="85" y2="50" stroke="#d1d5db" stroke-width="0.5"/>
                    <!-- N3: 75, 85 -->
                    <line x1="50" y1="50" x2="75" y2="85" stroke="#d1d5db" stroke-width="0.5"/>
                    <!-- N4: 25, 85 -->
                    <line x1="50" y1="50" x2="25" y2="85" stroke="#d1d5db" stroke-width="0.5"/>
                    <!-- N5: 15, 50 -->
                    <line x1="50" y1="50" x2="15" y2="50" stroke="#d1d5db" stroke-width="0.5"/>
                    
                    <!-- Inter-skill connection (Parallel / Backward) -->
                    <line x1="50" y1="15" x2="85" y2="50" stroke="#d1d5db" stroke-width="0.5" stroke-dasharray="2"/>
                    <!-- Обратная связь (Backward) -->
                    <path d="M 75 85 Q 50 100 25 85" fill="none" stroke="#f97316" stroke-width="0.5" stroke-dasharray="1"/>
                </svg>

                <!-- Центральный Агент -->
                <div class="absolute top-[50%] left-[50%] transform -translate-x-1/2 -translate-y-1/2 w-20 h-20 md:w-28 md:h-28 bg-gray-900 rounded-full flex items-center justify-center text-white font-black text-sm md:text-xl shadow-xl z-20">
                    Агент
                </div>
                
                <!-- Навыки -->
                <!-- Top (50, 15) -->
                <div class="absolute top-[15%] left-[50%] transform -translate-x-1/2 -translate-y-1/2 bg-white border-2 border-purple-400 p-2 md:p-3 rounded-lg shadow-sm text-[8px] md:text-sm font-bold z-10 whitespace-nowrap">Навык 1</div>
                <!-- Right (85, 50) -->
                <div class="absolute top-[50%] left-[85%] transform -translate-x-1/2 -translate-y-1/2 bg-white border-2 border-orange-400 p-2 md:p-3 rounded-lg shadow-sm text-[8px] md:text-sm font-bold z-10 whitespace-nowrap">Навык 2</div>
                <!-- Bottom Right (75, 85) -->
                <div class="absolute top-[85%] left-[75%] transform -translate-x-1/2 -translate-y-1/2 bg-white border-2 border-gray-300 p-2 md:p-3 rounded-lg shadow-sm text-[8px] md:text-sm font-bold z-10 whitespace-nowrap">Навык 3</div>
                <!-- Bottom Left (25, 85) -->
                <div class="absolute top-[85%] left-[25%] transform -translate-x-1/2 -translate-y-1/2 bg-white border-2 border-purple-400 p-2 md:p-3 rounded-lg shadow-sm text-[8px] md:text-sm font-bold z-10 whitespace-nowrap">Навык 4</div>
                <!-- Left (15, 50) -->
                <div class="absolute top-[50%] left-[15%] transform -translate-x-1/2 -translate-y-1/2 bg-white border-2 border-orange-400 p-2 md:p-3 rounded-lg shadow-sm text-[8px] md:text-sm font-bold z-10 whitespace-nowrap">Навык 5</div>
            </div>

            <div class="text-center font-bold text-[10px] md:text-sm text-gray-800 mb-4 md:mb-6">Навыки должны быть атомарными и измеримыми</div>

            <div class="flex flex-wrap justify-center gap-4 md:gap-8 mb-4 md:mb-6">
                <div class="flex items-center gap-1.5 md:gap-2"><div class="w-3 md:w-6 h-0.5 bg-gray-400"></div><span class="text-[8px] md:text-xs text-gray-500">Последовательные</span></div>
                <div class="flex items-center gap-1.5 md:gap-2"><div class="w-3 md:w-6 h-0.5" style="border-top: 2px dashed #9ca3af; height: 0; background: none;"></div><span class="text-[8px] md:text-xs text-gray-500">Параллельные</span></div>
                <div class="flex items-center gap-1.5 md:gap-2"><div class="w-3 md:w-6 h-0.5" style="border-top: 2px dotted #f97316; height: 0; background: none;"></div><span class="text-[8px] md:text-xs text-gray-500">Обратные</span></div>
            </div>

            <div class="bg-gray-100 p-2 md:p-3 rounded-lg text-center max-w-sm mx-auto">
                <p class="text-[9px] md:text-sm font-bold text-gray-800">Функция = Навык</p>
                <p class="text-[10px] md:text-base font-black text-purple-700 mt-1">Граф = Функциональная архитектура</p>
            </div>
        </div>
    </div>

    <!-- СЛАЙД 28: Зачем нужен граф навыков -->
